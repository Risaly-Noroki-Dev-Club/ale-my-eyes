import { LineEdit, Button, CheckBox, ScrollView, Palette } from "std-widgets.slint";
import { AppTheme } from "widgets.slint";

export component SettingsPopup inherits Rectangle {
    in property <string> provider: "";
    in property <string> api-key: "";
    in property <string> api-url: "";
    in property <string> model: "";
    in property <string> max-tokens-str: "4000";
    in property <bool> auto-speak: true;
    in property <bool> show-api-key: false;
    in property <bool> is-busy: false;
    in property <string> config-path: "";

    callback provider-changed(string);
    callback api-key-changed(string);
    callback api-url-changed(string);
    callback model-changed(string);
    callback max-tokens-changed(string);
    callback auto-speak-changed(bool);
    callback toggle-api-key-visible();
    callback save-settings();
    callback test-connection();
    callback close-settings();

    background: #000000.transparentize(0.5);

    Rectangle {
        width: 340px;
        height: 420px;
        background: Palette.background;
        border-radius: 12px;
        border-width: 1px;
        border-color: Palette.border;

        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            // 标题栏
            HorizontalLayout {
                spacing: 8px;
                alignment: space-between;
                Text {
                    text: "⚙ 设置";
                    font-size: AppTheme.base-font + 2px;
                    font-weight: 700;
                    color: Palette.foreground;
                    vertical-alignment: center;
                }
                Button {
                    text: "✕";
                    clicked => { root.close-settings(); }
                }
            }

            ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 8px;

                    // 云端 API
                    Text { text: "云端 API"; font-size: AppTheme.base-font; font-weight: 600; color: Palette.foreground; }

                    Text {
                        text: "Provider";
                        font-size: AppTheme.base-font - 2px;
                        color: Palette.foreground.transparentize(0.3);
                    }
                    LineEdit {
                        text: root.provider;
                        placeholder-text: "openai";
                        edited(text) => { root.provider-changed(text); }
                    }

                    Text {
                        text: "API Key";
                        font-size: AppTheme.base-font - 2px;
                        color: Palette.foreground.transparentize(0.3);
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        LineEdit {
                            text: root.api-key;
                            placeholder-text: "sk-...";
                            edited(text) => { root.api-key-changed(text); }
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: root.show-api-key ? "隐藏" : "显示";
                            clicked => { root.toggle-api-key-visible(); }
                        }
                    }

                    Text {
                        text: "API URL";
                        font-size: AppTheme.base-font - 2px;
                        color: Palette.foreground.transparentize(0.3);
                    }
                    LineEdit {
                        text: root.api-url;
                        placeholder-text: "https://api.openai.com/v1";
                        edited(text) => { root.api-url-changed(text); }
                    }

                    Text {
                        text: "Model";
                        font-size: AppTheme.base-font - 2px;
                        color: Palette.foreground.transparentize(0.3);
                    }
                    LineEdit {
                        text: root.model;
                        placeholder-text: "gpt-4o";
                        edited(text) => { root.model-changed(text); }
                    }

                    // Token 预算
                    Text { text: "Token 预算"; font-size: AppTheme.base-font; font-weight: 600; color: Palette.foreground; }
                    Text {
                        text: "上下文对话最大 token 数";
                        font-size: AppTheme.base-font - 2px;
                        color: Palette.foreground.transparentize(0.3);
                    }
                    LineEdit {
                        text: root.max-tokens-str;
                        placeholder-text: "4000";
                        edited(text) => { root.max-tokens-changed(text); }
                    }

                    // 界面选项
                    Text { text: "界面"; font-size: AppTheme.base-font; font-weight: 600; color: Palette.foreground; }
                    HorizontalLayout {
                        spacing: 8px;
                        CheckBox {
                            checked: root.auto-speak;
                            text: "自动语音播报";
                            toggled => { root.auto-speak-changed(self.checked); }
                        }
                    }

                    // 配置路径（只读）
                    if root.config-path != "" : VerticalLayout {
                        spacing: 4px;
                        Text { text: "配置文件"; font-size: AppTheme.base-font; font-weight: 600; color: Palette.foreground; }
                        Text {
                            text: root.config-path;
                            font-size: AppTheme.base-font - 4px;
                            color: Palette.foreground.transparentize(0.5);
                            wrap: word-wrap;
                        }
                    }
                }
            }

            // 操作按钮
            HorizontalLayout {
                spacing: 8px;
                Button {
                    text: "保存";
                    primary: true;
                    enabled: !root.is-busy;
                    clicked => { root.save-settings(); }
                }
                Button {
                    text: "测试连接";
                    enabled: !root.is-busy;
                    clicked => { root.test-connection(); }
                }
                Button {
                    text: "取消";
                    clicked => { root.close-settings(); }
                }
            }
        }
    }
}
