import { Palette } from "std-widgets.slint";

export global AppTheme {
    in property <bool> high-contrast: false;
    // 14px desktop / 16px mobile — set from Rust via set_is-mobile
    in property <bool> is-mobile: false;
    in property <length> base-font: root.is-mobile ? 16px : 14px;
    // 触控最小目标尺寸（Android 推荐 48dp，iOS 推荐 44pt）
    in property <length> touch-min: root.is-mobile ? 44px : 28px;
    // 移动端更大的内边距和间距
    in property <length> pad: root.is-mobile ? 12px : 8px;
    in property <length> gap: root.is-mobile ? 8px : 4px;
}

export component StatusDot inherits Rectangle {
    in property <string> state: "ready";
    width: root.state == "speaking" ? 12px : 10px;
    height: root.state == "speaking" ? 12px : 10px;
    border-radius: 6px;
    background: root.state == "speaking" ? #28a745
        : root.state == "processing" ? #ffc107
        : root.state == "error" ? #dc3545
        : root.state == "recording" ? #17a2b8
        : Palette.border;
}

export component TagPill inherits Rectangle {
    in property <string> label;
    in property <brush> accent: Palette.accent-background;
    height: 22px;
    border-radius: 11px;
    background: root.accent.transparentize(0.85);

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        alignment: center;
        Text {
            text: root.label;
            font-size: AppTheme.base-font - 3px;
            color: root.accent;
        }
    }
}

export component IconButton inherits Rectangle {
    in property <string> icon;
    in property <string> tooltip;
    in property <bool> active: false;
    callback clicked;
    // 触控友好：最小 44px（移动端）/ 28px（桌面）
    width: AppTheme.touch-min;
    height: AppTheme.touch-min;
    border-radius: 8px;
    background: touch.has-hover ? Palette.control-background : transparent;
    accessible-label: root.tooltip;
    accessible-role: button;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.icon;
        font-size: AppTheme.is-mobile ? 18px : 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: root.active ? Palette.accent-background : Palette.foreground;
    }
}
